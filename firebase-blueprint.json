{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "agent"] },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "approved", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "priceBoite": { "type": "number" },
        "pricePlaquette": { "type": "number" },
        "pricePillule": { "type": "number" },
        "purchasePriceBoite": { "type": "number" },
        "purchasePricePlaquette": { "type": "number" },
        "purchasePricePillule": { "type": "number" },
        "packsPerBox": { "type": "number" },
        "pillsPerPack": { "type": "number" },
        "totalQuantityPillules": { "type": "number" },
        "pharmacyQuantityPillules": { "type": "number" },
        "lowStockThresholdPillules": { "type": "number" },
        "source": { "type": "string" },
        "grossisteName": { "type": "string" },
        "showInPharmacy": { "type": "boolean" },
        "showInStock": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "totalQuantityPillules", "updatedAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sale information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "unit": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "agentId": { "type": "string" },
        "agentName": { "type": "string" },
        "cashierId": { "type": "string" },
        "cashierName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "agentId", "status", "createdAt"]
    },
    "InventoryLog": {
      "title": "Inventory Log",
      "description": "Log of inventory movements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["addition", "transfer_to_pharmacy", "return_to_stock", "stock_exit"] },
        "quantityPillules": { "type": "number" },
        "details": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "productName", "type", "quantityPillules", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales"
    },
    "/inventory-logs/{logId}": {
      "schema": "InventoryLog",
      "description": "Inventory movement logs"
    }
  }
}
