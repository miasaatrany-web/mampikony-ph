{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "agent"] },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "approved", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "expirationDate": { "type": "string", "format": "date-time" },
        "lowStockThreshold": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "quantity", "expirationDate", "updatedAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sale information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "agentId": { "type": "string" },
        "agentName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "agentId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales"
    }
  }
}
